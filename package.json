{
  "name": "treenote",
  "version": "1.0.0",
  "description": "Hierarchical notes management application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "typecheck": "tsc --noEmit",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:dir": "electron-vite build && electron-builder --win --dir --config electron-builder.yml"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^4.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
